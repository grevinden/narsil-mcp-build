#!/bin/sh
set -e

case "$1" in
    remove|purge)
        # Rebuild man page index on removal
        if command -v mandb >/dev/null 2>&1; then
            mandb -q || true
        fi
        ;;
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;
    *)
        ;;
esac

exit 0
